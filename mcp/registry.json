    {
      "name": "BackofficeListPage",
      "category": "page",
      "description": "백오피스 목록 조회 페이지 — 좌측 내비게이션, 상단 바, 페이지 타이틀+액션 버튼, 검색/필터 바, 총 건수 + 테이블 구조",
      "figmaNodeId": "6135:126884",
      "components": ["SideNavigation", "TopNavigation", "Button", "ButtonGroup", "Select", "Divider", "TextButton", "Table"],
      "structure": [
        { "section": "LNB", "component": "SideNavigation", "note": "좌측 고정 내비게이션. NavSectionHeader + NavItem 조합" },
        { "section": "TopNavigation", "component": "TopNavigation", "note": "상단 글로벌 헤더" },
        { "section": "title section", "components": ["(h1 텍스트)", "ButtonGroup > Button"], "note": "페이지 제목(좌) + 액션 버튼 그룹(우). 버튼은 주로 내보내기·일괄수정·추가 3개" },
        { "section": "Searchbox", "components": ["Select (×N)", "Divider", "Button (검색)", "Button (초기화)"], "note": "드롭다운 필터 여러 개 + 세로 구분선 + 검색/초기화 버튼" },
        { "section": "Count + Table", "components": ["(총 N건 텍스트)", "TextButton", "Table"], "note": "좌측 총 건수 텍스트, 우측 전체 초기화 TextButton, 아래 Table" }
      ],
      "example": "import { SideNavigation, TopNavigation, Button, ButtonGroup, Select, Divider, TextButton, Table } from 'igt-design-system-v4'\n\nexport function UserListPage() {\n  return (\n    <div className=\"flex h-screen\">\n      <SideNavigation>\n        <NavSectionHeader label=\"사용자 관리\" />\n        <NavItem label=\"사용자 목록\" active />\n        <NavItem label=\"권한 관리\" />\n      </SideNavigation>\n\n      <div className=\"flex flex-col flex-1\">\n        <TopNavigation />\n\n        <div className=\"flex flex-col gap-4 p-6\">\n          <div className=\"flex items-center justify-between\">\n            <h1>사용자 목록</h1>\n            <ButtonGroup>\n              <Button tone=\"secondary\" appearance=\"outline\" size=\"md\">내보내기</Button>\n              <Button tone=\"secondary\" appearance=\"outline\" size=\"md\">일괄 수정</Button>\n              <Button tone=\"primary\" appearance=\"fill\" size=\"md\">사용자 추가</Button>\n            </ButtonGroup>\n          </div>\n\n          <div className=\"flex items-center gap-3\">\n            <Select placeholder=\"상태\" />\n            <Select placeholder=\"권한\" />\n            <Select placeholder=\"가입일\" />\n            <Divider orientation=\"vertical\" />\n            <Button tone=\"primary\" appearance=\"fill\" size=\"md\">검색</Button>\n            <Button tone=\"secondary\" appearance=\"outline\" size=\"md\">초기화</Button>\n          </div>\n\n          <div className=\"flex items-center justify-between\">\n            <span>총 128건</span>\n            <TextButton>전체 초기화</TextButton>\n          </div>\n\n          <Table />\n        </div>\n      </div>\n    </div>\n  )\n}"
    }
  ]
