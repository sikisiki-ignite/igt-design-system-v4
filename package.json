{
  "name": "igt-design-system-v4",
  "version": "0.1.0",
  "description": "IGT Design System v4 — shadcn-style theme system + AI-optimized",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "mcp"
  ],
  "bin": {
    "igt-mcp": "./mcp/server.mjs"
  },
  "scripts": {
    "prepare": "npm run build",
    "build": "vite build && tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "vite build --watch",
    "showcase": "vite --config vite.config.showcase.ts",
    "build:showcase": "vite build --config vite.config.showcase.ts",
    "build:icons": "node scripts/build-icons.mjs",
    "fetch:icons": "node scripts/fetch-icons.mjs",
    "lint:css": "./node_modules/.bin/stylelint 'src/components/**/*.css'",
    "verify": "node scripts/visual-check.mjs",
    "verify:all": "node scripts/visual-check.mjs all",
    "struct-check": "node scripts/struct-check.mjs",
    "struct-check:all": "node scripts/struct-check.mjs all"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@svgr/cli": "^8.1.0",
    "@svgr/core": "^8.1.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.0",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "stylelint": "^17.9.1",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-css-injected-by-js": "^3.5.1",
    "vite-plugin-dts": "^4.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss": "^4.2.4",
    "clsx": "^2.1.1",
    "postcss": "^8.5.12",
    "tailwindcss": "^4.2.4"
  }
}
